{
  "name": "prana",
  "version": "1.1.8",
  "description": "Prana desktop application built with Electron and TypeScript",
  "main": "./out/main/index.js",
  "author": "Prana Team",
  "scripts": {
    "generate:index": "node scripts/generate-index.cjs",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev -- --no-sandbox",
    "build": "npm run typecheck && npm run generate:index && electron-vite build",
    "rebuild-deps": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "test": "npm run test:unit",
    "test:unit": "cross-env NODE_ENV=test vitest run",
    "test:unit:watch": "cross-env NODE_ENV=test vitest",
    "test:e2e": "cross-env NODE_ENV=test playwright test",
    "test:e2e:headed": "cross-env NODE_ENV=test HEADLESS=false playwright test --headed",
    "test:watch": "cross-env NODE_ENV=test HEADLESS=false playwright test --headed --ui",
    "test:e2e:show-report": "playwright show-report"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.10",
    "@mui/material": "7.3.10",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "@xenova/transformers": "^2.17.2",
    "astra": "github:NikhilVijayakumar/astra",
    "bcryptjs": "^3.0.3",
    "cron-parser": "^5.5.0",
    "dompurify": "^3.3.3",
    "html-to-docx": "^1.8.0",
    "isomorphic-dompurify": "^3.8.0",
    "js-tiktoken": "^1.0.21",
    "mammoth": "^1.12.0",
    "marked": "^17.0.5",
    "react-router-dom": "^7.13.1",
    "sharp": "^0.34.5",
    "sql.js": "^1.14.1",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.54.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.19.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "^3.7.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.0"
  }
}
