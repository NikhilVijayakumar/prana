{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "packages/dhi/**/*",
    "packages/astra/**/*",
    "packages/prana/ui/**/*",
    "packages/prana/services/**/*",
    "packages/dharma/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/renderer/src/*"
      ],
      "@prana/*": ["packages/prana/*"],
      "@dharma/*": ["packages/dharma/*"],
      "@dhi/*": ["packages/dhi/*"],
      "@astra/*": ["packages/astra/*"]
    }
  }
}
