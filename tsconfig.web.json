{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/ui/env.d.ts",
    "src/ui/**/*",
    "src/ui/**/*.tsx",
    "src/services/**/*",
    "src/preload/*.d.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/ui/*"
      ],
      "prana/*": ["src/*"],
      "@astra/*": ["node_modules/astra/*"]
    }
  }
}
