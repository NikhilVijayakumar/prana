# DHI Electron build-time environment template
# Commit this file. Do not commit real secrets.
# Preferred key format for electron-vite main process: MAIN_VITE_DHI_*

# Governance repository bootstrap
MAIN_VITE_DHI_GOV_REPO_URL=git@bitbucket.org:your-org/governance.git
MAIN_VITE_DHI_GOV_REPO_PATH=.dhi/governance

# Director identity seed (applied only on first auth store creation)
MAIN_VITE_DHI_DIRECTOR_NAME=Director Name
MAIN_VITE_DHI_DIRECTOR_EMAIL=director@yourorg.com

# Use exactly one password seed variable
# Option A (local/dev only):
# MAIN_VITE_DHI_DIRECTOR_PASSWORD=Director1
# Option B (recommended for production):
MAIN_VITE_DHI_DIRECTOR_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash

# Vault format/output controls
MAIN_VITE_DHI_VAULT_SPEC_VERSION=v1
MAIN_VITE_DHI_VAULT_TEMP_ZIP_EXT=.vzip
MAIN_VITE_DHI_VAULT_OUTPUT_PREFIX=dhi_vault_export_
MAIN_VITE_DHI_VAULT_ARCHIVE_PASSWORD=replace_with_strong_secret
MAIN_VITE_DHI_VAULT_ARCHIVE_SALT=replace_with_base64_salt
MAIN_VITE_DHI_VAULT_KDF_ITERATIONS=210000
# MAIN_VITE_DHI_VAULT_KEEP_TEMP_ON_CLOSE=false

# Future channels (optional)
# MAIN_VITE_DHI_TELEGRAM_CHANNEL_ID=
# MAIN_VITE_DHI_SLACK_CHANNEL_ID=
# MAIN_VITE_DHI_TEAMS_CHANNEL_ID=
